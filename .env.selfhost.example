# Copy to .env at the repo root before running `docker compose up`.
# Supabase is the one cloud dependency of the self-host stack (Postgres + Auth);
# use a free project or a self-hosted Supabase instance.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxx
SUPABASE_ANON_KEY=xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
# Optional: token shared between the API and the bundled Redis REST proxy
# SRH_TOKEN=change-me
