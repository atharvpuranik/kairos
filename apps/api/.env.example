# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxx

# Upstash Redis
UPSTASH_REDIS_REST_URL=xxxx
UPSTASH_REDIS_REST_TOKEN=xxxx

# Anthropic (eval computation — used starting Week 3, optional for now)
ANTHROPIC_API_KEY=

# Eval provider: "anthropic" (documented default) or "gemini" (dev/test
# stand-in — get a free key at aistudio.google.com/apikey)
EVAL_PROVIDER=anthropic
GEMINI_API_KEY=

# Inngest (background jobs — used starting Week 3, optional for now)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
APP_ENV=development
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# v1.1 — optional (sane defaults in config.py)
SUPABASE_ANON_KEY=
RATE_LIMIT_PER_MINUTE=120
FREE_TIER_TRACES_PER_MONTH=10000
EVAL_MAX_ATTEMPTS=3
EVAL_DAILY_CAP_PER_USER=2000
